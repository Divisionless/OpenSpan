# ============================================================
# OpenSpan .gitignore — pre-publication local snapshot.
# Keeps secrets and large binaries OUT of version control so this
# tree can be published later without leaking anything.
# ============================================================

# --- SECRETS: never commit (private SSH keys) ---
id_openspan
id_openspan.pub
id_laptop
id_laptop.pub
*.pem
*.key

# --- Large binaries / the VM itself ---
*.raw
debian-*.raw
vm/

# --- Transient logs & runtime scratch output ---
*.log
win/app-err.txt
win/app-out.txt
win/err.txt
win/out.txt
win/sender-err.txt

# --- Python / editor junk ---
__pycache__/
*.pyc
*.pyo

# local settings hold the clipboard relay token -- never publish it
openspan_settings.json

# runtime state written by the compact balance slider
audio_balance.txt

# PyInstaller build artifacts (the 64MB exe is built on demand, not tracked)
build/
dist/
OpenSpan.exe
*.spec

# personal / machine-specific runtime state (never publish)
bt_prefs.json
openspan_config.json
mode.txt

# internal working notes (not part of the public project)
HANDOFF-PROMPT.md
CODE_REVIEW_2026-07-10.md
mouse-lag-research-prompt.md
preview-*.png
