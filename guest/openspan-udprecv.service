[Unit]
Description=OpenSpan UDP audio bridge (Windows audio -> Bluetooth sink)
After=openspan-wireplumber.service
Requires=openspan-wireplumber.service

[Service]
Environment=XDG_RUNTIME_DIR=/run/openspan
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/openspan/bus
ExecStartPre=/bin/sleep 4
ExecStart=/usr/bin/python3 /opt/openspan/udp_to_sink.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
